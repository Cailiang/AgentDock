{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "AgentDock",
  "version": "0.1.11",
  "identifier": "com.agentdock.desktop",
  "build": {
    "beforeDevCommand": "npm run dev:ui",
    "beforeBuildCommand": "npm run build:ui",
    "devUrl": "http://127.0.0.1:1420",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "AgentDock",
        "width": 1280,
        "height": 820,
        "minWidth": 900,
        "minHeight": 640,
        "resizable": true,
        "fullscreen": false,
        "center": true,
        "visible": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "category": "DeveloperTool",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "shortDescription": "Beginner-friendly AI coding client manager",
    "longDescription": "AgentDock installs and manages AI coding clients, providers, Skills, MCP servers, usage statistics, and diagnostics from one native desktop app."
  }
}
